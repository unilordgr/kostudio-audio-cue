{
  "name": "kostudio-audio-cue",
  "version": "1.0.0",
  "description": "Kostudio Audio Cue — Live Performance Sound Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist-win": "electron-builder --win --publish never",
    "dist-mac": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.kostudio.audiocue",
    "productName": "Kostudio Audio Cue",
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.music"
    },
    "dmg": {
      "title": "Kostudio Audio Cue"
    }
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  }
}
